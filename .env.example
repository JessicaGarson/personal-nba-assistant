PORT=4321
HOST=127.0.0.1

# Nimble
NIMBLE_API_KEY=
NIMBLE_API_BASE_URL=https://sdk.nimbleway.com/v1
NIMBLE_SEARCH_URL=https://nimble-retriever.webit.live/search
NIMBLE_EXTRACT_URL=https://sdk.nimbleway.com/v1/extract

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=wav
OPENAI_TTS_TIMEOUT_MS=60000

# Calendar
CALENDAR_ICS_URL=
CALENDAR_LOOKBACK_HOURS=24
CALENDAR_LOOKAHEAD_HOURS=0

# Agent preferences
FAVORITE_TEAMS=Knicks,Liberty
DEFAULT_TIMEZONE=America/New_York
OUTPUT_DIR=./output
BLOB_AUDIO_PATH_PREFIX=recaps
BLOB_STORE_ACCESS=public

# Delivery
PUBLIC_BASE_URL=http://127.0.0.1:4321
# Optional: set this to a Discord, Slack, or test webhook endpoint for npm run send
DELIVERY_WEBHOOK_URL=
DELIVERY_DESTINATION_NAME=text-message-bridge
ASSISTANT_MIN_BUSY_MINUTES=45

# Vercel cron automation
CRON_SECRET=
CRON_TIMEZONE=America/New_York
CRON_ALLOWED_DATES=2026-05-12,2026-05-13

# Production audio storage for Vercel deployments
# Use `public` for direct browser URLs or `private` to stream audio through /api/audio
BLOB_READ_WRITE_TOKEN=
